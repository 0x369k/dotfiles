# Verbesserte zi-info Funktion
zi_info() {
    clear
    
    # Stilisierte Гњberschrift fГјr "Overall ZI status"
    _msg_"Overall ZI status"
    zi zstatus
    echo
    
    # Stilisierte Гњberschrift fГјr "Show loaded plugins"
    _msg_ "Show loaded plugins"
    zi loaded
    echo
    
    # Stilisierte Гњberschrift fГјr "Statistics on plugin load times"
    _msg_ "Plugin Load Times"
    zi times
    echo
    
    # Stilisierte Гњberschrift fГјr "BIN Directory Listing"
    _msg_ "BIN Directory Listing"
    ls -l $ZPFX/bin/ | awk '{print $(NF-2),$(NF-1),$NF}'
}
